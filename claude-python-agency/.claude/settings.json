{
  "agent": "orchestrator",
  "permissions": {
    "allow": [
      "Bash(python -m mypy *)",
      "Bash(python -m ruff *)",
      "Bash(python -m pytest *)",
      "Bash(python -m pip list *)",
      "Bash(python -m pip show *)",
      "Bash(python -c *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Read",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Write(CLAUDE.md)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(docs/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(pip install *)",
      "Bash(python -m pip install *)",
      "Read(.env.production)",
      "Read(**/.env.local)",
      "Read(**/credentials*)",
      "Read(**/*secret*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python -m ruff check --fix \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>&1 | tail -5 && python -m ruff format \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>&1 | tail -5"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '--- Project Health ---' && python -m mypy src/ 2>&1 | tail -20 && echo '--- Done ---'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); CMD=$(echo \"$INPUT\" | jq -r '.tool_input.command // empty'); case \"$CMD\" in *'rm -rf'*|*'--force'*|*'reset --hard'*|*'pip install'*) echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"decision\":{\"behavior\":\"block\",\"reason\":\"Destructive or unauthorized command blocked by project policy.\"}}}'; exit 0;; *) exit 0;; esac"
          }
        ]
      }
    ]
  }
}